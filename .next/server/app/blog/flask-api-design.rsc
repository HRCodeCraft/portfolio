/60 leading-relaxed border-l-2 pl-5","style":{"borderColor":"#34d39960"},"children":"I've built Flask APIs ranging from a simple blog backend to a full ERP system. The ones that stayed maintainable shared the same structural decisions. The ones that became nightmares skipped the same shortcuts. Here's what I wish I'd known earlier."}],["$","div",null,{"className":"flex flex-wrap gap-2 mt-8","children":[["$","span","Flask",{"className":"text-xs px-2.5 py-1 rounded-full font-medium","style":{"color":"#34d399","background":"#34d39910","border":"1px solid #34d39925"},"children":"Flask"}],["$","span","REST API",{"className":"text-xs px-2.5 py-1 rounded-full font-medium","style":{"color":"#34d399","background":"#34d39910","border":"1px solid #34d39925"},"children":"REST API"}],["$","span","Python",{"className":"text-xs px-2.5 py-1 rounded-full font-medium","style":{"color":"#34d399","background":"#34d39910","border":"1px solid #34d39925"},"children":"Python"}],["$","span","Architecture",{"className":"text-xs px-2.5 py-1 rounded-full font-medium","style":{"color":"#34d399","background":"#34d39910","border":"1px solid #34d39925"},"children":"Architecture"}],["$","span","Blueprints",{"className":"text-xs px-2.5 py-1 rounded-full font-medium","style":{"color":"#34d399","background":"#34d39910","border":"1px solid #34d39925"},"children":"Blueprints"}]]}]]}],["$","div",null,{"className":"h-px w-full mb-12 opacity-20","style":{"background":"linear-gradient(90deg, transparent, #34d399, transparent)"}}],["$","div",null,{"className":"space-y-10","children":[["$","section","Use Blueprints from Day One",{"children":[["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mb-5 leading-snug","children":"Use Blueprints from Day One"}],["$","div",null,{"children":[["$","div","0",{"children":[["$","p","0",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"The single biggest structural mistake in Flask apps is putting all routes in a single <code class=\"px-1.5 py-0.5 rounded bg-white/8 text-[#ff4d6d] text-[13px] font-mono\">app.py</code>. Blueprints are Flask's module system — use them before you need them, not after."}}],null]}],["$","div","1",{"className":"relative my-6 rounded-2xl overflow-hidden border border-white/8","children":[["$","div",null,{"className":"flex items-center gap-1.5 px-4 py-2.5 bg-white/4 border-b border-white/6","children":[["$","span","0",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ff5f56"}}],["$","span","1",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ffbd2e"}}],["$","span","2",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#27c93f"}}]]}],["$","pre",null,{"className":"overflow-x-auto p-5 text-xs leading-relaxed text-white/75 font-mono bg-[#0d0d18]","children":["$","code",null,{"children":"# project structure\napp/\n├── __init__.py        # app factory\n├── blueprints/\n│   ├── auth/\n│   │   ├── __init__.py\n│   │   └── routes.py\n│   ├── posts/\n│   │   ├── __init__.py\n│   │   └── routes.py\n│   └── admin/\n│       ├── __init__.py\n│       └── routes.py\n└── models.py\n\n# blueprints/posts/routes.py\nfrom flask import Blueprint, jsonify, request\n\nposts_bp = Blueprint('posts', __name__, url_prefix='/api/v1/posts')\n\n@posts_bp.route('/', methods=['GET'])\ndef list_posts():\n    ...\n\n@posts_bp.route('/<int:post_id>', methods=['GET'])\ndef get_post(post_id):\n    ...\n\n# app/__init__.py — factory pattern\ndef create_app(config=None):\n    app = Flask(__name__)\n\n    from .blueprints.posts.routes import posts_bp\n    from .blueprints.auth.routes import auth_bp\n\n    app.register_blueprint(posts_bp)\n    app.register_blueprint(auth_bp)\n\n    return app"}]}]]}],["$","div","2",{"children":[null,["$","p","1",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"The factory pattern also makes testing trivial — create a fresh app instance with test config for each test."}}]]}]]}]]}],["$","section","Consistent Error Responses",{"children":[["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mb-5 leading-snug","children":"Consistent Error Responses"}],["$","div",null,{"children":[["$","div","0",{"children":[["$","p","0",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"Nothing frustrates API consumers more than inconsistent error formats. Define one error schema and enforce it globally."}}],null]}],["$","div","1",{"className":"relative my-6 rounded-2xl overflow-hidden border border-white/8","children":[["$","div",null,{"className":"flex items-center gap-1.5 px-4 py-2.5 bg-white/4 border-b border-white/6","children":[["$","span","0",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ff5f56"}}],["$","span","1",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ffbd2e"}}],["$","span","2",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#27c93f"}}]]}],["$","pre",null,{"className":"overflow-x-auto p-5 text-xs leading-relaxed text-white/75 font-mono bg-[#0d0d18]","children":["$","code",null,{"children":"# errors.py\nfrom flask import jsonify\nfrom http import HTTPStatus\n\nclass APIError(Exception):\n    def __init__(self, message: str, status_code: int = 400, error_code: str = None):\n        self.message = message\n        self.status_code = status_code\n        self.error_code = error_code or f\"ERR_{status_code}\"\n        super().__init__(message)\n\ndef register_error_handlers(app):\n    @app.errorhandler(APIError)\n    def handle_api_error(e):\n        return jsonify({\n            \"error\": {\n                \"code\": e.error_code,\n                \"message\": e.message,\n                \"status\": e.status_code\n            }\n        }), e.status_code\n\n    @app.errorhandler(404)\n    def not_found(e):\n        return jsonify({\"error\": {\"code\": \"NOT_FOUND\", \"message\": \"Resource not found\", \"status\": 404}}), 404\n\n    @app.errorhandler(500)\n    def internal_error(e):\n        return jsonify({\"error\": {\"code\": \"INTERNAL_ERROR\", \"message\": \"An unexpected error occurred\", \"status\": 500}}), 500"}]}]]}],["$","div","2",{"children":[null,["$","p","1",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"Every error response always has the same shape. Frontend developers can write a single error handler."}}]]}]]}]]}],["$","section","Request Validation Before Business Logic",{"children":[["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mb-5 leading-snug","children":"Request Validation Before Business Logic"}],["$","div",null,{"children":[["$","div","0",{"children":[["$","p","0",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"Never let malformed data reach your business logic. Validate at the route layer."}}],null]}],["$","div","1",{"className":"relative my-6 rounded-2xl overflow-hidden border border-white/8","children":[["$","div",null,{"className":"flex items-center gap-1.5 px-4 py-2.5 bg-white/4 border-b border-white/6","children":[["$","span","0",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ff5f56"}}],["$","span","1",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ffbd2e"}}],["$","span","2",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#27c93f"}}]]}],["$","pre",null,{"className":"overflow-x-auto p-5 text-xs leading-relaxed text-white/75 font-mono bg-[#0d0d18]","children":["$","code",null,{"children":"from functools import wraps\nfrom flask import request, jsonify\n\ndef require_json_fields(*required_fields):\n    def decorator(fn):\n        @wraps(fn)\n        def wrapper(*args, **kwargs):\n            data = request.get_json(silent=True)\n            if not data:\n                raise APIError(\"Request body must be valid JSON\", 400)\n\n            missing = [f for f in required_fields if f not in data or data[f] is None]\n            if missing:\n                raise APIError(\n                    f\"Missing required fields: {', '.join(missing)}\",\n                    400,\n                    \"MISSING_FIELDS\"\n                )\n            return fn(*args, **kwargs)\n        return wrapper\n    return decorator\n\n# Usage\n@posts_bp.route('/', methods=['POST'])\n@require_json_fields('title', 'content', 'author_id')\ndef create_post():\n    data = request.get_json()\n    # data is guaranteed to have title, content, author_id\n    ..."}]}]]}],["$","div","2",{"children":[null]}]]}]]}],["$","section","Versioning and Pagination",{"children":[["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mb-5 leading-snug","children":"Versioning and Pagination"}],["$","div",null,{"children":[["$","div","0",{"children":[["$","p","0",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"Version your API from the start — changing it later requires coordinating with all consumers simultaneously."}}],null]}],["$","div","1",{"className":"relative my-6 rounded-2xl overflow-hidden border border-white/8","children":[["$","div",null,{"className":"flex items-center gap-1.5 px-4 py-2.5 bg-white/4 border-b border-white/6","children":[["$","span","0",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ff5f56"}}],["$","span","1",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ffbd2e"}}],["$","span","2",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#27c93f"}}]]}],["$","pre",null,{"className":"overflow-x-auto p-5 text-xs leading-relaxed text-white/75 font-mono bg-[#0d0d18]","children":["$","code",null,{"children":"# Always prefix with /api/v{N}\nurl_prefix='/api/v1/posts'\n\n# Standard pagination — never return unbounded lists\n@posts_bp.route('/', methods=['GET'])\ndef list_posts():\n    page = request.args.get('page', 1, type=int)\n    per_page = min(request.args.get('per_page', 20, type=int), 100)  # cap at 100\n\n    total = db.execute(\"SELECT COUNT(*) FROM posts WHERE status='published'\").fetchone()[0]\n    posts = db.execute(\n        \"SELECT * FROM posts WHERE status='published' ORDER BY created_at DESC LIMIT ? OFFSET ?\",\n        [per_page, (page - 1) * per_page]\n    ).fetchall()\n\n    return jsonify({\n        \"data\": [dict(p) for p in posts],\n        \"pagination\": {\n            \"page\": page,\n            \"per_page\": per_page,\n            \"total\": total,\n            \"pages\": (total + per_page - 1) // per_page,\n            \"has_next\": page * per_page < total,\n            \"has_prev\": page > 1\n        }\n    })"}]}]]}],["$","div","2",{"children":[null]}]]}]]}],["$","section","Authentication Middleware",{"children":[["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mb-5 leading-snug","children":"Authentication Middleware"}],["$","div",null,{"children":[["$","div","0",{"children":[["$","p","0",{"className":"text-white/65 text-[15px] leading-[1.85] mb-4","dangerouslySetInnerHTML":{"__html":"Role-based auth as a decorator keeps route handlers clean and authorization logic centralized."}}],null]}],["$","div","1",{"className":"relative my-6 rounded-2xl overflow-hidden border border-white/8","children":[["$","div",null,{"className":"flex items-center gap-1.5 px-4 py-2.5 bg-white/4 border-b border-white/6","children":[["$","span","0",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ff5f56"}}],["$","span","1",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#ffbd2e"}}],["$","span","2",{"className":"w-2.5 h-2.5 rounded-full","style":{"background":"#27c93f"}}]]}],["$","pre",null,{"className":"overflow-x-auto p-5 text-xs leading-relaxed text-white/75 font-mono bg-[#0d0d18]","children":["$","code",null,{"children":"$9"}]}]]}],["$","div","2",{"children":[null]}]]}]]}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-white/8 flex flex-col sm:flex-row items-